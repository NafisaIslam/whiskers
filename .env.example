# Copy to .env and fill in.

DJANGO_SECRET_KEY=replace-with-output-of-python-manage.py-shell-get_random_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (psycopg3 DSN)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/whiskers

# JWT
JWT_SIGNING_KEY=replace-with-random-hex-string
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=14

# CORS (frontend origins, comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
